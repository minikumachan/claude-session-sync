# Normalize line endings across platforms
* text=auto eol=lf

# Shell scripts MUST be LF (CRLF breaks the shebang on macOS/Linux)
*.sh text eol=lf

# PowerShell scripts are committed UTF-8 WITH BOM and checked out byte-for-byte
# (-text = no EOL/encoding conversion) so the BOM always survives — required for
# Windows PowerShell 5.1 to read non-ASCII correctly on every clone.
*.ps1 -text
