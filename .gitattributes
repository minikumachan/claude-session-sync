# Normalize line endings across platforms
* text=auto eol=lf

# Shell scripts MUST be LF (CRLF breaks the shebang on macOS/Linux)
*.sh text eol=lf

# PowerShell: CRLF + UTF-8 BOM so Windows PowerShell 5.1 does not mis-decode non-ASCII
# (working-tree-encoding adds the BOM on checkout for everyone who clones)
*.ps1 text eol=crlf working-tree-encoding=UTF-8-BOM
